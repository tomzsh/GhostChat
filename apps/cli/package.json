{
  "name": "@ghostchat/cli",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ghost": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ghostchat/crypto": "workspace:*",
    "@ghostchat/protocol": "workspace:*",
    "@ghostchat/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
