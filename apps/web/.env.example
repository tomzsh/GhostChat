# Optional. If unset, REST uses same-origin Next rewrites → worker.
# WebSocket still needs an absolute worker URL.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8787

# Server-side rewrite target for /api/* (defaults to http://127.0.0.1:8787)
# WORKER_URL=http://127.0.0.1:8787
